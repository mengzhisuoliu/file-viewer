{
  "name": "file-viewer",
  "version": "1.0.26",
  "environment": {
    "framework": "vue3",
    "viewerSite": "https://demo.file-viewer.app",
    "docs": "https://doc.file-viewer.app"
  },
  "packages": {
    "vue3": "@flyfish-group/file-viewer3@1.0.26",
    "vue2": "@flyfish-group/file-viewer@1.0.26"
  },
  "features": [
    {
      "group": "document",
      "extensions": ["doc", "docx", "docm", "dot", "dotx", "dotm", "rtf", "odt", "pdf", "ofd", "typ", "typst"],
      "lazyLoaded": true,
      "defaultScale": "fit-width"
    },
    {
      "group": "drawing",
      "extensions": ["dxf", "dwg", "dwf", "dwfx", "xps", "geojson", "kml", "gpx", "shp", "excalidraw", "drawio", "dio"],
      "notes": ["CAD uses @flyfish-dev/cad-viewer", "DWG uses Worker + LibreDWG WASM", "DWF/DWFx/XPS use native dwf-viewer", "Excalidraw uses a roughjs SVG fallback", "draw.io uses diagrams.net GraphViewer"]
    },
    {
      "group": "model",
      "extensions": ["glb", "gltf", "obj", "stl", "ply", "fbx", "dae", "3ds", "3mf", "amf", "usd", "usda", "usdc", "usdz", "kmz", "pcd", "wrl", "vrml", "xyz", "vtk", "vtp", "step", "stp", "iges", "igs", "ifc", "3dm"],
      "renderer": "three.js",
      "lazyLoaded": true
    },
    {
      "group": "ebook",
      "extensions": ["epub", "umd"],
      "renderer": "epubjs-or-umd-parser",
      "lazyLoaded": true
    },
    {
      "group": "source",
      "extensions": ["js", "ts", "tsx", "vue", "react", "json", "jsonc", "json5", "ipynb", "yaml", "toml", "proto", "hcl", "tex", "gv", "http", "sql", "rb", "swift", "kt"],
      "renderer": "highlight.js",
      "executeHtml": false
    },
    {
      "group": "asset-data",
      "extensions": ["ttf", "otf", "woff", "woff2", "psd", "ai", "eps", "sqlite", "wasm", "parquet", "avro", "webarchive"],
      "renderer": "native-or-structured-parser",
      "lazyLoaded": true
    }
  ],
  "qualityGate": {
    "typeCheck": true,
    "build": true,
    "browserSmoke": ["sample-picker", "code-preview", "pdf-toolbar"]
  },
  "updatedAt": "2026-06-17T10:30:00+08:00"
}
