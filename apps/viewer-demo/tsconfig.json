{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "../../packages/components/vue3/src/env.d.ts",
    "../../packages/core/src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.d.ts"
  ],
  "compilerOptions": {
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@/package/*": ["../../packages/components/vue3/src/package/*"],
      "@/*": ["./src/*"],
      "@file-viewer/core": ["../../packages/core/src/index.ts"],
      "@file-viewer/vue3": ["../../packages/components/vue3/src/package/index.ts"],
      "@file-viewer/web": ["../../packages/components/web/src/index.ts"],
      "@flyfish-group/file-viewer3": ["../../packages/components/vue3/src/package/index.ts"]
    },
    "ignoreDeprecations": "6.0",
    "declaration": true
  }
}
