flowchart LR
  user([User]) --> app[Official Demo]
  app --> core["@file-viewer/core"]
  core --> registry{Renderer Registry}
  registry --> office[Office Renderers]
  registry --> drawing[Drawing Renderers]
  registry --> code[Code Renderers]
  registry --> data[Data Asset Renderers]
  drawing --> mermaid[Mermaid]
  drawing --> plantuml[PlantUML]
  data --> psd[PSD Layers]
  code --> patch[Patch Diff]
  code --> bundle[Git Bundle]
  mermaid --> svg[Theme-aware SVG]
  plantuml --> umlSvg[Server-rendered SVG]
  psd --> layers[Layer Toggle + Zoom]
  patch --> sideBySide[Side-by-side Compare]
  bundle --> history[History + File Tree]
